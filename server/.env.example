# StadiumPulse backend configuration.
# Copy this file to `.env` and fill in real values — the server fails fast at
# boot if any required variable is missing (see src/config/env.js).

# Required — PostgreSQL connection string (e.g. a Supabase database URL).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Required — Google Gemini API key used for crisis-response generation.
GEMINI_API_KEY=your-gemini-api-key

# Required — shared operations access code, seeded into the database on first
# boot only. Rotations afterward happen via the in-app change-code flow.
ACCESS_CODE=choose-a-code-min-6-chars

# Optional — port to listen on (default 3000). Hosting platforms usually
# inject this automatically.
# PORT=3000

# Optional — set to "true" to serve canned AI responses instead of calling
# Gemini (useful for demos and running without an API key).
# MOCK_MODE=false

# Optional — the deployed frontend origin to allow via CORS, in addition to
# localhost dev servers (e.g. https://your-app.netlify.app).
# FRONTEND_URL=
